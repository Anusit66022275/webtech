<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>จัดการผู้ใช้ | Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
</head>
<body>
  <header class="header py-2">
    <div class="container d-flex align-items-center justify-content-between">
      <h1 style="font-size:1.4rem;">NUI MANGA STORE — Admin</h1>
      <div class="d-flex gap-2">
        <a href="/admin" class="btn btn-outline-light btn-sm"><i class="bi bi-grid me-1"></i>Dashboard</a>
        <a href="/admin/orders" class="btn btn-outline-light btn-sm"><i class="bi bi-bag me-1"></i>Orders</a>
        <a href="/admin/coupons" class="btn btn-outline-light btn-sm"><i class="bi bi-ticket me-1"></i>Coupons</a>
        <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i></a>
      </div>
    </div>
  </header>

  <main class="container py-4">
    <h2 class="mb-4"><i class="bi bi-people me-2"></i>จัดการผู้ใช้ (<%= users.length %>)</h2>

    <div id="toast-area" style="position:fixed;top:70px;right:16px;z-index:9999;"></div>

    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-dark">
            <tr>
              <th>#</th><th>ชื่อผู้ใช้</th><th>อีเมล</th><th>Role</th><th>สถานะ</th><th>จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
            <tr id="user-row-<%= u.user_id %>">
              <td><%= u.user_id %></td>
              <td><%= u.username %></td>
              <td><%= u.email %></td>
              <td>
                <select class="form-select form-select-sm role-select" data-id="<%= u.user_id %>" style="width:100px;">
                  <option value="user"  <%- u.role === 'user'  ? 'selected' : '' %>>user</option>
                  <option value="admin" <%- u.role === 'admin' ? 'selected' : '' %>>admin</option>
                </select>
              </td>
              <td>
                <% if (u.is_active) { %>
                  <span class="badge bg-success">ปกติ</span>
                <% } else { %>
                  <span class="badge bg-danger">ระงับแล้ว</span>
                <% } %>
              </td>
              <td>
                <button class="btn btn-sm <%= u.is_active ? 'btn-outline-danger' : 'btn-outline-success' %> btn-toggle"
                  data-id="<%= u.user_id %>" data-active="<%= u.is_active %>">
                  <i class="bi bi-<%= u.is_active ? 'slash-circle' : 'check-circle' %>"></i>
                  <%= u.is_active ? 'ระงับ' : 'เปิดใช้' %>
                </button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function showMsg(msg, ok) {
      const t = document.createElement('div');
      t.className = `alert alert-${ok ? 'success' : 'danger'} py-2 px-3`;
      t.style = 'min-width:220px;font-size:13px;';
      t.textContent = msg;
      document.getElementById('toast-area').appendChild(t);
      setTimeout(() => t.remove(), 3000);
    }

    document.querySelectorAll('.role-select').forEach(sel => {
      sel.addEventListener('change', function() {
        fetch(`/admin/users/${this.dataset.id}/role`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role: this.value })
        }).then(r => r.json()).then(d => showMsg(d.message || (d.success ? 'เปลี่ยน role สำเร็จ' : 'ผิดพลาด'), d.success));
      });
    });

    document.querySelectorAll('.btn-toggle').forEach(btn => {
      btn.addEventListener('click', function() {
        fetch(`/admin/users/${this.dataset.id}/toggle`, { method: 'POST' })
          .then(r => r.json())
          .then(d => {
            if (d.success) location.reload();
            else showMsg(d.message || 'ผิดพลาด', false);
          });
      });
    });
  </script>
</body>
</html>
