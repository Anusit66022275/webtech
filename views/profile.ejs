<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>โปรไฟล์ | NUI MANGA STORE</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
  <script src="/javascript/darkmode.js"></script>
  <style>
    /* ── Avatar ── */
    .avatar-circle {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--yellow), #ff9f43);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      font-weight: 800;
      color: var(--dark);
      margin: 0 auto 12px;
      box-shadow: 0 4px 16px rgba(255,193,7,0.35);
      text-transform: uppercase;
    }

    /* ── Profile cards ── */
    .profile-card {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
      margin-bottom: 20px;
    }
    .profile-card-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      font-size: 15px;
      font-weight: 700;
    }
    .profile-card-header i {
      font-size: 18px;
      color: var(--yellow-dark);
    }
    .profile-card-body { padding: 20px; }

    /* ── Info row ── */
    .info-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 14px;
      background: var(--bg);
      border-radius: 10px;
      margin-bottom: 10px;
    }
    .info-row i { font-size: 20px; color: var(--muted); flex-shrink: 0; }
    .info-label { font-size: 12px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 2px; }
    .info-value { font-size: 15px; font-weight: 700; }

    /* ── Save buttons ── */
    .btn-profile-save {
      background: var(--yellow);
      color: var(--dark);
      border: none;
      border-radius: 8px;
      padding: 10px 28px;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-profile-save:hover { background: var(--yellow-dark); }

    /* ── Alert ── */
    .profile-alert {
      border-radius: 10px;
      font-size: 14px;
      padding: 10px 16px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .profile-alert-success {
      background: #d1fae5;
      color: #065f46;
      border-left: 4px solid #22c55e;
    }
    .profile-alert-error {
      background: #fde8e8;
      color: #842029;
      border-left: 4px solid #ef4444;
    }

    /* ── Dark mode ── */
    [data-theme="dark"] .profile-card { background: var(--white); }
    [data-theme="dark"] .profile-card-header { border-bottom-color: var(--border); }
    [data-theme="dark"] .info-row { background: #252836; }
    [data-theme="dark"] .form-control,
    [data-theme="dark"] .form-select {
      background: #252836 !important;
      border-color: var(--border) !important;
      color: var(--text) !important;
    }
    [data-theme="dark"] .form-control::placeholder { color: var(--muted); }
    [data-theme="dark"] .profile-alert-success { background: #063a24; color: #4ade80; }
    [data-theme="dark"] .profile-alert-error   { background: #3a0d0d; color: #f87171; }
    [data-theme="dark"] .form-label { color: var(--text); }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="header py-2">
    <div class="container">
      <div class="row align-items-center g-2">
        <div class="col-md-4">
          <h1>NUI MANGA STORE</h1>
        </div>
        <div class="col-md-4">
          <div class="search-bar">
            <input type="text" id="search-input" placeholder="ค้นหาหนังสือการ์ตูน..." class="form-control">
            <button class="btn btn-danger" onclick="searchBooks()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-4 text-end d-flex align-items-center justify-content-end gap-2">
          <button id="dark-mode-btn" class="btn btn-outline-light" onclick="toggleDarkMode()" title="Dark Mode" style="padding:6px 10px;"><i class="bi bi-moon-fill"></i></button>
          <a href="/cart" class="btn btn-outline-light"><i class="bi bi-cart3"></i> ตะกร้า</a>
          <% if (user) { %>
            <button class="btn btn-outline-light position-relative" id="notif-btn" style="padding:6px 10px;" title="การแจ้งเตือน">
              <i class="bi bi-bell-fill"></i>
              <% if (typeof unreadNotifCount !== 'undefined' && unreadNotifCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:10px;"><%= unreadNotifCount %></span>
              <% } %>
            </button>
            <a href="/profile" class="btn btn-outline-light active" title="โปรไฟล์" style="padding:6px 10px;"><i class="bi bi-person-gear"></i></a>
            <a href="/logout" class="btn btn-outline-light"><i class="bi bi-box-arrow-right"></i> ออก</a>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light"><i class="bi bi-person"></i> เข้าสู่ระบบ</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/home"><i class="bi bi-book-half me-1"></i>NUI MANGA STORE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">หมวดหมู่</a>
            <ul class="dropdown-menu">
              <% (genres || []).forEach(g => { %>
              <li><a class="dropdown-item" href="/Book?category=<%= encodeURIComponent(g) %>"><%= g %></a></li>
              <% }) %>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/wishlist"><i class="bi bi-heart me-1"></i>รายการโปรด</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/order-history">ประวัติการซื้อ</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/profile"><i class="bi bi-person-circle me-1"></i>โปรไฟล์</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <div class="container py-5">

      <h2 class="section-heading mb-4"><i class="bi bi-person-circle me-2"></i>โปรไฟล์ของฉัน</h2>

      <% if (success) { %>
        <div class="profile-alert profile-alert-success">
          <i class="bi bi-check-circle-fill"></i> <%= success %>
        </div>
      <% } %>
      <% if (error) { %>
        <div class="profile-alert profile-alert-error">
          <i class="bi bi-exclamation-circle-fill"></i> <%= error %>
        </div>
      <% } %>

      <div class="row g-4">

        <!-- Left: info -->
        <div class="col-lg-4">
          <div class="profile-card">
            <div class="profile-card-body text-center py-4">
              <div class="avatar-circle">
                <%= profile.username.charAt(0) %>
              </div>
              <div style="font-size:20px;font-weight:800;margin-bottom:4px;"><%= profile.username %></div>
              <div style="font-size:13px;color:var(--muted);"><%= profile.email %></div>
            </div>
          </div>

          <div class="profile-card">
            <div class="profile-card-header">
              <i class="bi bi-info-circle"></i> ข้อมูลบัญชี
            </div>
            <div class="profile-card-body">
              <div class="info-row">
                <i class="bi bi-person"></i>
                <div>
                  <div class="info-label">ชื่อผู้ใช้</div>
                  <div class="info-value"><%= profile.username %></div>
                </div>
              </div>
              <div class="info-row mb-0">
                <i class="bi bi-envelope"></i>
                <div>
                  <div class="info-label">อีเมล (สำหรับล็อกอิน)</div>
                  <div class="info-value"><%= profile.email %></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: forms -->
        <div class="col-lg-8">

          <!-- Change username -->
          <div class="profile-card">
            <div class="profile-card-header">
              <i class="bi bi-person-gear"></i> เปลี่ยนชื่อผู้ใช้
            </div>
            <div class="profile-card-body">
              <form action="/profile/username" method="POST">
                <div class="mb-3">
                  <label class="form-label fw-semibold">ชื่อผู้ใช้ใหม่</label>
                  <input type="text" class="form-control" name="username"
                         value="<%= profile.username %>"
                         minlength="3" required
                         placeholder="อย่างน้อย 3 ตัวอักษร">
                </div>
                <button type="submit" class="btn-profile-save">
                  <i class="bi bi-check-lg me-1"></i>บันทึกชื่อผู้ใช้
                </button>
              </form>
            </div>
          </div>

          <!-- Change password -->
          <div class="profile-card">
            <div class="profile-card-header">
              <i class="bi bi-shield-lock"></i> เปลี่ยนรหัสผ่าน
            </div>
            <div class="profile-card-body">
              <form action="/profile/password" method="POST">
                <div class="mb-3">
                  <label class="form-label fw-semibold">รหัสผ่านปัจจุบัน</label>
                  <input type="password" class="form-control" name="current_password"
                         required placeholder="กรอกรหัสผ่านเดิม">
                </div>
                <div class="row g-3 mb-4">
                  <div class="col-sm-6">
                    <label class="form-label fw-semibold">รหัสผ่านใหม่</label>
                    <input type="password" class="form-control" name="new_password"
                           required minlength="6" placeholder="อย่างน้อย 6 ตัวอักษร">
                  </div>
                  <div class="col-sm-6">
                    <label class="form-label fw-semibold">ยืนยันรหัสผ่านใหม่</label>
                    <input type="password" class="form-control" name="confirm_password"
                           required minlength="6" placeholder="พิมพ์ซ้ำอีกครั้ง">
                  </div>
                </div>
                <button type="submit" class="btn-profile-save">
                  <i class="bi bi-lock me-1"></i>บันทึกรหัสผ่าน
                </button>
              </form>
            </div>
          </div>

        </div>
      </div>

    </div>
  </main>

  <!-- SEARCH MODAL -->
  <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold">ผลการค้นหา</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3" id="search-results-container"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="bg-dark text-white text-center py-4">
    <p class="mb-1 fw-bold" style="color:#ffc107;">NUI MANGA STORE</p>
    <p class="mb-2" style="font-size:13px;">&copy; 2025 Nui&amp;Dream.com | All Rights Reserved</p>
    <p class="mb-0">
      <a href="#" class="text-white-50 me-3"><i class="bi bi-facebook"></i></a>
      <a href="#" class="text-white-50 me-3"><i class="bi bi-twitter-x"></i></a>
      <a href="#" class="text-white-50"><i class="bi bi-instagram"></i></a>
    </p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascript/toast.js"></script>
  <script src="/javascript/transition.js"></script>
  <script src="/javascript/search.js"></script>

  <!-- Notification dropdown -->
  <div id="notif-dropdown" style="display:none;position:fixed;width:320px;max-height:400px;overflow-y:auto;background:#fff;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,.2);z-index:1020;">
    <div style="padding:12px 16px;border-bottom:1px solid #eee;font-weight:600;">การแจ้งเตือน</div>
    <div id="notif-list" style="padding:8px 0;"></div>
  </div>
  <% if (user) { %>
  <script src="/javascript/notifications.js"></script>
  <% } %>
</body>
</html>
