<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ชำระเงิน | NUI MANGA STORE</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
  <link rel="stylesheet" href="/css/checkout.css">
  <script src="/javascript/darkmode.js"></script>
</head>
<body>

  <!-- HEADER -->
  <header class="header py-2">
    <div class="container">
      <div class="row align-items-center g-2">
        <div class="col-md-4">
          <h1>NUI MANGA STORE</h1>
        </div>
        <div class="col-md-4">
          <div class="search-bar">
            <input type="text" id="search-input" placeholder="ค้นหาหนังสือการ์ตูน..." class="form-control">
            <button class="btn btn-danger" onclick="searchBooks()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-4 text-end d-flex align-items-center justify-content-end gap-2">
          <button id="dark-mode-btn" class="btn btn-outline-light" onclick="toggleDarkMode()" title="Dark Mode" style="padding:6px 10px;"><i class="bi bi-moon-fill"></i></button>
          <a href="/cart" class="btn btn-outline-light"><i class="bi bi-cart3"></i> ตะกร้า</a>
          <% if (user) { %>
            <button class="btn btn-outline-light position-relative" id="notif-btn" style="padding:6px 10px;" title="การแจ้งเตือน">
              <i class="bi bi-bell-fill"></i>
              <% if (unreadNotifCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:10px;"><%= unreadNotifCount %></span>
              <% } %>
            </button>
            <a href="/profile" class="btn btn-outline-light" title="โปรไฟล์" style="padding:6px 10px;"><i class="bi bi-person-gear"></i></a>
            <a href="/logout" class="btn btn-outline-light"><i class="bi bi-box-arrow-right"></i> ออก</a>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light"><i class="bi bi-person"></i> เข้าสู่ระบบ</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/home"><i class="bi bi-book-half me-1"></i>NUI MANGA STORE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">หมวดหมู่</a>
            <ul class="dropdown-menu">
              <% (genres || []).forEach(g => { %>
              <li><a class="dropdown-item" href="/Book?category=<%= encodeURIComponent(g) %>"><%= g %></a></li>
              <% }) %>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/wishlist"><i class="bi bi-heart me-1"></i>รายการโปรด</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/order-history">ประวัติการซื้อ</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <div class="container py-5">
      <h2 class="section-heading mb-4"><i class="bi bi-credit-card me-2"></i>ชำระเงิน</h2>

      <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
      <% } %>

      <div class="row g-4">
        <!-- Order summary -->
        <div class="col-lg-5">
          <div class="checkout-panel">
            <h3><i class="bi bi-receipt me-2"></i>สรุปคำสั่งซื้อ</h3>
            <% cart.forEach(item => { %>
            <div class="checkout-item">
              <img src="<%= item.image || '/uploads/default.png' %>"
                   onerror="this.src='/uploads/default.png'" alt="<%= item.title %>">
              <div>
                <div class="item-name"><%= item.title %></div>
                <div class="item-sub">จำนวน <%= item.quantity %> เล่ม × ฿<%= Number(item.price).toLocaleString() %></div>
              </div>
              <div class="item-total">฿<%= (item.price * item.quantity).toLocaleString() %></div>
            </div>
            <% }) %>
            <div class="checkout-total">
              <span>ยอดรวม</span>
              <span class="amount">฿<%= totalPrice.toLocaleString() %></span>
            </div>
          </div>
        </div>

        <!-- Payment form -->
        <div class="col-lg-7">
          <div class="form-panel">
            <h4><i class="bi bi-person-lines-fill me-2"></i>ข้อมูลการจัดส่ง &amp; ชำระเงิน</h4>
            <form action="/checkout" method="POST" enctype="multipart/form-data">
              <div class="mb-3">
                <label class="form-label">ชื่อ-นามสกุล</label>
                <input type="text" class="form-control" name="name" placeholder="กรอกชื่อ-นามสกุล" required>
              </div>
              <div class="mb-3">
                <label class="form-label">ที่อยู่จัดส่ง</label>
                <input type="text" class="form-control" name="address" placeholder="กรอกที่อยู่จัดส่ง" required>
              </div>
              <div class="mb-4">
                <label class="form-label">เบอร์โทรศัพท์</label>
                <input type="tel" class="form-control" name="phone_number"
                       placeholder="เช่น 0812345678"
                       pattern="0[0-9\-]{8,10}"
                       title="เบอร์โทร 9-10 หลัก ขึ้นต้นด้วย 0 เช่น 0812345678"
                       required>
                <div class="form-text text-muted" style="font-size:12px;">ขึ้นต้นด้วย 0 มี 9-10 หลัก เช่น 0812345678</div>
              </div>

              <div class="mb-3">
                <label class="form-label">โค้ดส่วนลด (ถ้ามี)</label>
                <div class="input-group">
                  <input type="text" class="form-control" id="coupon-input" placeholder="กรอกโค้ดส่วนลด">
                  <button class="btn btn-outline-secondary" type="button" id="btn-apply-coupon">ใช้โค้ด</button>
                </div>
                <div id="coupon-msg" class="form-text"></div>
                <input type="hidden" name="coupon_code" id="coupon-code-hidden">
                <input type="hidden" name="discount" id="discount-hidden" value="0">
              </div>

              <div class="qr-wrap">
                <img src="https://www.scb.co.th/getmedia/2f609c0d-4ec2-4682-a194-137f66371bad/qr-code-generated-7.jpg"
                     alt="QR Code สำหรับโอนเงิน">
                <p>สแกน QR Code เพื่อโอนเงิน แล้วแนบสลิปด้านล่าง</p>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold">แนบสลิปการโอนเงิน</label>
                <input type="file" class="form-control" name="paymentSlip" accept="image/*" required>
              </div>

              <button type="submit" class="btn-pay">
                <i class="bi bi-check-circle me-2"></i>ยืนยันการชำระเงิน
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- SEARCH MODAL -->
  <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold">ผลการค้นหา</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3" id="search-results-container"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="bg-dark text-white text-center py-4">
    <p class="mb-1 fw-bold" style="color:#ffc107;">NUI MANGA STORE</p>
    <p class="mb-2" style="font-size:13px;">&copy; 2025 Nui&amp;Dream.com | All Rights Reserved</p>
    <p class="mb-0">
      <a href="#" class="text-white-50 me-3"><i class="bi bi-facebook"></i></a>
      <a href="#" class="text-white-50 me-3"><i class="bi bi-twitter-x"></i></a>
      <a href="#" class="text-white-50"><i class="bi bi-instagram"></i></a>
    </p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascript/toast.js"></script>
  <script src="/javascript/transition.js"></script>
  <script src="/javascript/search.js"></script>
  <script>
    const totalPrice = <%= totalPrice %>;
    document.getElementById('btn-apply-coupon').addEventListener('click', function() {
      const code = document.getElementById('coupon-input').value.trim();
      if (!code) return;
      fetch('/coupon/validate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, total_price: totalPrice })
      })
      .then(r => r.json())
      .then(data => {
        const msg = document.getElementById('coupon-msg');
        if (data.success) {
          msg.style.color = 'green';
          msg.textContent = `ลด ${data.discount_percent}% = -฿${data.discount.toLocaleString()}`;
          document.getElementById('coupon-code-hidden').value = code;
          document.getElementById('discount-hidden').value = data.discount;
        } else {
          msg.style.color = 'red';
          msg.textContent = data.message;
          document.getElementById('coupon-code-hidden').value = '';
          document.getElementById('discount-hidden').value = 0;
        }
      });
    });
  </script>

  <!-- Notification dropdown -->
  <div id="notif-dropdown" style="display:none;position:fixed;width:320px;max-height:400px;overflow-y:auto;background:#fff;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,.2);z-index:1020;">
    <div style="padding:12px 16px;border-bottom:1px solid #eee;font-weight:600;">การแจ้งเตือน</div>
    <div id="notif-list" style="padding:8px 0;"></div>
  </div>
  <script src="/javascript/notifications.js"></script>
</body>
</html>
