<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ชำระเงิน | NUI MANGA STORE</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
  <link rel="stylesheet" href="/css/checkout.css">
</head>
<body>

  <!-- HEADER -->
  <header class="header py-2">
    <div class="container">
      <div class="row align-items-center g-2">
        <div class="col-md-4">
          <h1>NUI MANGA STORE</h1>
        </div>
        <div class="col-md-4">
          <div class="search-bar">
            <input type="text" id="search-input" placeholder="ค้นหาหนังสือการ์ตูน..." class="form-control">
            <button class="btn btn-danger" onclick="searchBooks()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-4 text-end d-flex align-items-center justify-content-end gap-2">
          <a href="/cart" class="btn btn-outline-light"><i class="bi bi-cart3"></i> ตะกร้า</a>
          <% if (user) { %>
            <a href="/logout" class="btn btn-outline-light"><i class="bi bi-box-arrow-right"></i> ออก</a>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light"><i class="bi bi-person"></i> เข้าสู่ระบบ</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/home"><i class="bi bi-book-half me-1"></i>NUI MANGA STORE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">หมวดหมู่</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/Book?category=แอคชั่น">แอคชั่น</a></li>
              <li><a class="dropdown-item" href="/Book?category=โรแมนซ์">โรแมนซ์</a></li>
              <li><a class="dropdown-item" href="/Book?category=กีฬา">กีฬา</a></li>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/order-history">ประวัติการซื้อ</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <div class="container py-5">
      <h2 class="section-heading mb-4"><i class="bi bi-credit-card me-2"></i>ชำระเงิน</h2>

      <div class="row g-4">
        <!-- Order summary -->
        <div class="col-lg-5">
          <div class="checkout-panel">
            <h3><i class="bi bi-receipt me-2"></i>สรุปคำสั่งซื้อ</h3>
            <% cart.forEach(item => { %>
            <div class="checkout-item">
              <img src="<%= item.image && item.image.startsWith('http') ? item.image : '/uploads/' + (item.image || 'default.png') %>"
                   onerror="this.src='/uploads/default.png'" alt="<%= item.title %>">
              <div>
                <div class="item-name"><%= item.title %></div>
                <div class="item-sub">จำนวน <%= item.quantity %> เล่ม × ฿<%= Number(item.price).toLocaleString() %></div>
              </div>
              <div class="item-total">฿<%= (item.price * item.quantity).toLocaleString() %></div>
            </div>
            <% }) %>
            <div class="checkout-total">
              <span>ยอดรวม</span>
              <span class="amount">฿<%= totalPrice.toLocaleString() %></span>
            </div>
          </div>
        </div>

        <!-- Payment form -->
        <div class="col-lg-7">
          <div class="form-panel">
            <h4><i class="bi bi-person-lines-fill me-2"></i>ข้อมูลการจัดส่ง &amp; ชำระเงิน</h4>
            <form action="/checkout" method="POST" enctype="multipart/form-data">
              <div class="mb-3">
                <label class="form-label">ชื่อ-นามสกุล</label>
                <input type="text" class="form-control" name="name" placeholder="กรอกชื่อ-นามสกุล" required>
              </div>
              <div class="mb-3">
                <label class="form-label">ที่อยู่จัดส่ง</label>
                <input type="text" class="form-control" name="address" placeholder="กรอกที่อยู่จัดส่ง" required>
              </div>
              <div class="mb-4">
                <label class="form-label">เบอร์โทรศัพท์</label>
                <input type="text" class="form-control" name="phone_number" placeholder="0xx-xxx-xxxx" required>
              </div>

              <div class="qr-wrap">
                <img src="https://www.scb.co.th/getmedia/2f609c0d-4ec2-4682-a194-137f66371bad/qr-code-generated-7.jpg"
                     alt="QR Code สำหรับโอนเงิน">
                <p>สแกน QR Code เพื่อโอนเงิน แล้วแนบสลิปด้านล่าง</p>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold">แนบสลิปการโอนเงิน</label>
                <input type="file" class="form-control" name="paymentSlip" accept="image/*" required>
              </div>

              <button type="submit" class="btn-pay">
                <i class="bi bi-check-circle me-2"></i>ยืนยันการชำระเงิน
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- SEARCH MODAL -->
  <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold">ผลการค้นหา</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3" id="search-results-container"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="bg-dark text-white text-center py-4">
    <p class="mb-1 fw-bold" style="color:#ffc107;">NUI MANGA STORE</p>
    <p class="mb-2" style="font-size:13px;">&copy; 2025 Nui&amp;Dream.com | All Rights Reserved</p>
    <p class="mb-0">
      <a href="#" class="text-white-50 me-3"><i class="bi bi-facebook"></i></a>
      <a href="#" class="text-white-50 me-3"><i class="bi bi-twitter-x"></i></a>
      <a href="#" class="text-white-50"><i class="bi bi-instagram"></i></a>
    </p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascript/toast.js"></script>
  <script src="/javascript/transition.js"></script>
  <script src="/javascript/search.js"></script>
</body>
</html>
