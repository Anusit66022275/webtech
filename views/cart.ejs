<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ตะกร้าสินค้า | NUI MANGA STORE</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
  <link rel="stylesheet" href="/css/cart.css">
  <script src="/javascript/darkmode.js"></script>
</head>
<body>

  <!-- HEADER -->
  <header class="header py-2">
    <div class="container">
      <div class="row align-items-center g-2">
        <div class="col-md-4">
          <h1>NUI MANGA STORE</h1>
        </div>
        <div class="col-md-4">
          <div class="search-bar">
            <input type="text" id="search-input" placeholder="ค้นหาหนังสือการ์ตูน..." class="form-control">
            <button class="btn btn-danger" onclick="searchBooks()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-4 text-end d-flex align-items-center justify-content-end gap-2">
          <button id="dark-mode-btn" class="btn btn-outline-light" onclick="toggleDarkMode()" title="Dark Mode" style="padding:6px 10px;"><i class="bi bi-moon-fill"></i></button>
          <a href="/cart" class="btn btn-outline-light"><i class="bi bi-cart3"></i> ตะกร้า</a>
          <% if (user) { %>
            <a href="/profile" class="btn btn-outline-light" title="โปรไฟล์" style="padding:6px 10px;"><i class="bi bi-person-gear"></i></a>
            <a href="/logout" class="btn btn-outline-light"><i class="bi bi-box-arrow-right"></i> ออก</a>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light"><i class="bi bi-person"></i> เข้าสู่ระบบ</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/home"><i class="bi bi-book-half me-1"></i>NUI MANGA STORE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">หมวดหมู่</a>
            <ul class="dropdown-menu">
              <% (genres || []).forEach(g => { %>
              <li><a class="dropdown-item" href="/Book?category=<%= encodeURIComponent(g) %>"><%= g %></a></li>
              <% }) %>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/order-history">ประวัติการซื้อ</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <div class="container py-4">
      <h2 class="section-heading mb-4"><i class="bi bi-cart3 me-2"></i>ตะกร้าสินค้า</h2>

      <% if (cart && cart.length > 0) { %>
        <div class="row g-4">
          <!-- Cart items -->
          <div class="col-lg-8">
            <div id="cart-items-list">
              <% cart.forEach((item, index) => { %>
              <div class="cart-item-card">
                <img class="item-img"
                     src="<%= item.image || '/uploads/default.png' %>"
                     onerror="this.src='/uploads/default.png'"
                     alt="<%= item.title %>">
                <div class="item-info">
                  <div class="item-title"><%= item.title %></div>
                  <p class="item-price">฿<%= Number(item.price).toLocaleString() %></p>
                </div>
                <div class="d-flex flex-column align-items-center gap-2">
                  <div class="qty-control">
                    <button class="qty-btn" onclick="updateCart(<%= index %>, 'decrease')">−</button>
                    <span class="qty-value"><%= item.quantity %></span>
                    <button class="qty-btn" onclick="updateCart(<%= index %>, 'increase')">+</button>
                  </div>
                  <button class="btn-remove" onclick="removeFromCart(<%= index %>)" title="ลบสินค้า">
                    <i class="bi bi-trash3"></i>
                  </button>
                </div>
              </div>
              <% }) %>
            </div>
          </div>

          <!-- Summary -->
          <div class="col-lg-4">
            <div class="cart-summary">
              <div class="summary-title"><i class="bi bi-receipt me-2"></i>สรุปคำสั่งซื้อ</div>
              <div class="summary-row">
                <span>จำนวนรายการ</span>
                <span id="cart-item-count"><%= cart.length %> รายการ</span>
              </div>
              <div class="summary-row total">
                <span>รวมทั้งหมด</span>
                <span id="total-price">฿<%= totalPrice.toLocaleString() %></span>
              </div>
              <button class="btn-checkout" onclick="goToCheckout()">
                <i class="bi bi-credit-card me-2"></i>ชำระเงิน
              </button>
              <a href="/Book" class="btn-continue">
                <i class="bi bi-arrow-left me-1"></i>เลือกซื้อต่อ
              </a>
            </div>
          </div>
        </div>

      <% } else { %>
        <div class="empty-cart">
          <i class="bi bi-cart-x"></i>
          <p>ตะกร้าสินค้าว่างเปล่า</p>
          <a href="/Book" class="btn-shop">เลือกซื้อสินค้า</a>
        </div>
      <% } %>
    </div>
  </main>

  <!-- SEARCH MODAL -->
  <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold">ผลการค้นหา</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3" id="search-results-container"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="bg-dark text-white text-center py-4">
    <p class="mb-1 fw-bold" style="color:#ffc107;">NUI MANGA STORE</p>
    <p class="mb-2" style="font-size:13px;">&copy; 2025 Nui&amp;Dream.com | All Rights Reserved</p>
    <p class="mb-0">
      <a href="#" class="text-white-50 me-3"><i class="bi bi-facebook"></i></a>
      <a href="#" class="text-white-50 me-3"><i class="bi bi-twitter-x"></i></a>
      <a href="#" class="text-white-50"><i class="bi bi-instagram"></i></a>
    </p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascript/toast.js"></script>
  <script src="/javascript/transition.js"></script>
  <script src="/javascript/cart.js"></script>
  <script src="/javascript/search.js"></script>
</body>
</html>
