<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= book.title %> | NUI MANGA STORE</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
  <link rel="stylesheet" href="/css/book-details.css">
  <script src="/javascript/darkmode.js"></script>
</head>
<body>

  <!-- HEADER -->
  <header class="header py-2">
    <div class="container">
      <div class="row align-items-center g-2">
        <div class="col-md-4">
          <h1>NUI MANGA STORE</h1>
        </div>
        <div class="col-md-4">
          <div class="search-bar">
            <input type="text" id="search-input" placeholder="ค้นหาหนังสือการ์ตูน..." class="form-control">
            <button class="btn btn-danger" onclick="searchBooks()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-4 text-end d-flex align-items-center justify-content-end gap-2">
          <button id="dark-mode-btn" class="btn btn-outline-light" onclick="toggleDarkMode()" title="Dark Mode" style="padding:6px 10px;"><i class="bi bi-moon-fill"></i></button>
          <a href="/cart" class="btn btn-outline-light"><i class="bi bi-cart3"></i> ตะกร้า</a>
          <% if (user) { %>
                        <button class="btn btn-outline-light position-relative" id="notif-btn" style="padding:6px 10px;" title="การแจ้งเตือน">
              <i class="bi bi-bell-fill"></i>
              <% if (unreadNotifCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:10px;"><%= unreadNotifCount %></span>
              <% } %>
            </button>            <a href="/profile" class="btn btn-outline-light" title="โปรไฟล์" style="padding:6px 10px;"><i class="bi bi-person-gear"></i></a>
            <a href="/logout" class="btn btn-outline-light"><i class="bi bi-box-arrow-right"></i> ออก</a>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light"><i class="bi bi-person"></i> เข้าสู่ระบบ</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/home"><i class="bi bi-book-half me-1"></i>NUI MANGA STORE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">หมวดหมู่</a>
            <ul class="dropdown-menu">
              <% (genres || []).forEach(g => { %>
              <li><a class="dropdown-item" href="/Book?category=<%= encodeURIComponent(g) %>"><%= g %></a></li>
              <% }) %>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/wishlist"><i class="bi bi-heart me-1"></i>รายการโปรด</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/order-history">ประวัติการซื้อ</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <div class="container py-5">

      <!-- Book detail -->
      <div class="detail-panel">
        <div class="row g-4">
          <div class="col-md-4 d-flex align-items-start justify-content-center">
            <img class="book-cover"
                 src="<%= book.image %>"
                 onerror="this.src='/uploads/default.png'"
                 alt="<%= book.title %>">
          </div>
          <div class="col-md-8">
            <span class="book-genre-badge"><%= book.genre || 'มังงะ' %></span>
            <h1 class="book-title-lg"><%= book.title %></h1>
            <div class="book-price-lg">฿<%= Number(book.price).toLocaleString() %></div>
            <% if (book.stock === 0) { %>
              <div class="book-stock-lg" style="color:var(--red);font-weight:700;">
                <i class="bi bi-x-circle me-1"></i>สินค้าหมด
              </div>
            <% } else { %>
              <div class="book-stock-lg"><i class="bi bi-box-seam me-1"></i>คงเหลือ <%= book.stock %> เล่ม</div>
            <% } %>
            <p class="book-desc"><%= book.description %></p>
            <% if (book.stock === 0) { %>
              <button class="btn-add-cart" disabled
                style="background:#dee2e6;color:#6c757d;cursor:not-allowed;opacity:0.7;">
                <i class="bi bi-slash-circle"></i> สินค้าหมด
              </button>
            <% } else { %>
              <button class="btn-add-cart" id="btn-add-cart"
                data-id="<%= book.id %>"
                data-title="<%= book.title %>"
                data-price="<%= book.price %>"
                data-image="<%= book.image %>">
                <i class="bi bi-cart-plus"></i> เพิ่มลงตะกร้า
              </button>
            <% } %>
            <% if (user) { %>
            <button class="btn-add-cart mt-2" id="btn-wishlist" data-id="<%= book.id %>"
              style="background:<%= wishlisted ? '#dc3545' : 'transparent' %>;color:<%= wishlisted ? '#fff' : '#dc3545' %>;border:2px solid #dc3545;">
              <i class="bi bi-heart<%= wishlisted ? '-fill' : '' %> me-1"></i>
              <span><%= wishlisted ? 'บันทึกแล้ว' : 'บันทึกในรายการโปรด' %></span>
            </button>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Review form -->
      <div class="review-panel">
        <h4><i class="bi bi-star me-2"></i>เพิ่มรีวิวของคุณ</h4>
        <% if (user) { %>
          <div class="reviewer-info">
            <i class="bi bi-person-circle me-1"></i>
            กำลังรีวิวในฐานะ: <strong><%= user %></strong>
          </div>
          <div class="review-form">
            <div class="mb-3">
              <select id="rating" class="form-select">
                <option value="5">⭐⭐⭐⭐⭐ (5 ดาว)</option>
                <option value="4">⭐⭐⭐⭐ (4 ดาว)</option>
                <option value="3">⭐⭐⭐ (3 ดาว)</option>
                <option value="2">⭐⭐ (2 ดาว)</option>
                <option value="1">⭐ (1 ดาว)</option>
              </select>
            </div>
            <div class="mb-3">
              <textarea id="comment" class="form-control" rows="3" placeholder="เขียนรีวิวของคุณ..."></textarea>
            </div>
            <button class="btn-review" onclick="addReview()">
              <i class="bi bi-send me-1"></i>ส่งรีวิว
            </button>
          </div>
        <% } else { %>
          <div class="login-prompt">
            <i class="bi bi-lock me-1"></i>
            <a href="/login">เข้าสู่ระบบ</a> เพื่อเขียนรีวิวหนังสือ
          </div>
        <% } %>
      </div>

      <!-- Review list -->
      <div class="review-panel">
        <h4><i class="bi bi-chat-square-text me-2"></i>รีวิวจากผู้ใช้</h4>
        <div id="reviews-list">
          <p class="text-muted" style="font-size:14px;">กำลังโหลดรีวิว...</p>
        </div>
      </div>

    </div>
  </main>

  <!-- SEARCH MODAL -->
  <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold">ผลการค้นหา</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3" id="search-results-container"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="bg-dark text-white text-center py-4">
    <p class="mb-1 fw-bold" style="color:#ffc107;">NUI MANGA STORE</p>
    <p class="mb-2" style="font-size:13px;">&copy; 2025 Nui&amp;Dream.com | All Rights Reserved</p>
    <p class="mb-0">
      <a href="#" class="text-white-50 me-3"><i class="bi bi-facebook"></i></a>
      <a href="#" class="text-white-50 me-3"><i class="bi bi-twitter-x"></i></a>
      <a href="#" class="text-white-50"><i class="bi bi-instagram"></i></a>
    </p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascript/toast.js"></script>
  <script src="/javascript/transition.js"></script>
  <script src="/javascript/cart.js"></script>
  <script src="/javascript/search.js"></script>

  <script>
    const bookId      = "<%= book.id %>";
    const currentUser = <%- JSON.stringify(user || '') %>;
    const isAdminUser = <%- userRole === 'admin' ? 'true' : 'false' %>;

    const addCartBtn = document.getElementById('btn-add-cart');
    if (addCartBtn) {
      addCartBtn.addEventListener('click', function() {
        const { id, title, price, image } = this.dataset;
        addToCart(id, title, price, image);
      });
    }

    const wishlistBtn = document.getElementById('btn-wishlist');
    if (wishlistBtn) {
      wishlistBtn.addEventListener('click', function() {
        const bookId = this.dataset.id;
        fetch('/wishlist/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ book_id: bookId })
        })
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            const icon = this.querySelector('i');
            const span = this.querySelector('span');
            if (data.wishlisted) {
              icon.className = 'bi bi-heart-fill me-1';
              span.textContent = 'บันทึกแล้ว';
              showToast('เพิ่มในรายการโปรดแล้ว', 'success');
            } else {
              icon.className = 'bi bi-heart me-1';
              span.textContent = 'บันทึกในรายการโปรด';
              showToast('ลบออกจากรายการโปรดแล้ว', 'warning');
            }
          }
        });
      });
    }

    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function loadReviews() {
      fetch(`/reviews/${bookId}`)
        .then(res => res.json())
        .then(reviews => {
          const container = document.getElementById("reviews-list");
          if (reviews.length === 0) {
            container.innerHTML = '<p class="text-muted" style="font-size:14px;">ยังไม่มีรีวิวสำหรับหนังสือเล่มนี้</p>';
            return;
          }
          container.innerHTML = reviews.map(r => {
            const canDelete = currentUser && (isAdminUser || r.user === currentUser);
            return `
            <div class="review-item" id="review-${r.id}">
              <div class="d-flex justify-content-between align-items-start">
                <div class="reviewer-name"><i class="bi bi-person-circle me-1"></i>${escapeHtml(r.user)}</div>
                ${canDelete ? `<button class="btn-review-delete" onclick="deleteReview(${r.id})" title="ลบรีวิว"><i class="bi bi-trash"></i></button>` : ''}
              </div>
              <div class="review-stars">${'⭐'.repeat(Number(r.rating))}</div>
              <div class="review-comment">${escapeHtml(r.comment)}</div>
            </div>`;
          }).join('');
        })
        .catch(() => {
          document.getElementById("reviews-list").innerHTML = '<p class="text-muted">โหลดรีวิวไม่สำเร็จ</p>';
        });
    }

    function addReview() {
      const rating  = document.getElementById("rating").value;
      const comment = document.getElementById("comment").value.trim();

      if (!comment) { showToast("กรุณาเขียนรีวิวก่อนส่ง", "warning"); return; }

      fetch("/reviews", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ book_id: bookId, rating, comment })
      })
      .then(res => res.json())
      .then(result => {
        if (result.success) {
          showToast("เพิ่มรีวิวสำเร็จ!", "success");
          document.getElementById("comment").value = "";
          loadReviews();
        } else {
          showToast("เกิดข้อผิดพลาด: " + (result.error || "ไม่ทราบสาเหตุ"), "error");
        }
      });
    }

    function deleteReview(id) {
      if (!confirm('ลบรีวิวนี้?')) return;
      fetch(`/reviews/${id}`, { method: 'DELETE' })
        .then(r => r.json())
        .then(res => {
          if (res.success) {
            document.getElementById(`review-${id}`)?.remove();
            showToast('ลบรีวิวสำเร็จ', 'success');
            const list = document.getElementById('reviews-list');
            if (!list.querySelector('.review-item')) {
              list.innerHTML = '<p class="text-muted" style="font-size:14px;">ยังไม่มีรีวิวสำหรับหนังสือเล่มนี้</p>';
            }
          } else {
            showToast(res.error || 'เกิดข้อผิดพลาด', 'error');
          }
        });
    }

    document.addEventListener("DOMContentLoaded", loadReviews);
  </script>


  <!-- Notification dropdown -->
  <div id="notif-dropdown" style="display:none;position:fixed;width:320px;max-height:400px;overflow-y:auto;background:#fff;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,.2);z-index:1020;">
    <div style="padding:12px 16px;border-bottom:1px solid #eee;font-weight:600;">การแจ้งเตือน</div>
    <div id="notif-list" style="padding:8px 0;"></div>
  </div>
  <script src="/javascript/notifications.js"></script>
</body>
</html>
