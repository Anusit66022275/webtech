<!-- หน้าระบบจัดการแก้ไข ลบ เพิ่ม admin.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>หน้าแอดมิน</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/shared.css">
    <link rel="stylesheet" href="/css/admin.css">
    <script src="/javascript/darkmode.js"></script>
</head>
<body>

  <header class="header py-2">
    <div class="container">
      <div class="row align-items-center g-2">
        <div class="col-md-4">
          <h1>NUI MANGA STORE</h1>
        </div>
        <div class="col-md-4">
          <div class="search-bar">
            <input type="text" id="search-input" placeholder="ค้นหาหนังสือการ์ตูน..." class="form-control">
            <button class="btn btn-danger" onclick="searchBooks()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-4 text-end d-flex align-items-center justify-content-end gap-2">
          <button id="dark-mode-btn" class="btn btn-outline-light" onclick="toggleDarkMode()" title="Dark Mode" style="padding:6px 10px;"><i class="bi bi-moon-fill"></i></button>
          <a href="/cart" class="btn btn-outline-light"><i class="bi bi-cart3"></i> ตะกร้า</a>
          <% if (user) { %>
            <a href="/logout" class="btn btn-outline-light"><i class="bi bi-box-arrow-right"></i> ออก</a>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light"><i class="bi bi-person"></i> เข้าสู่ระบบ</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/home"><i class="bi bi-book-half me-1"></i>NUI MANGA STORE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">หมวดหมู่</a>
            <ul class="dropdown-menu">
              <% (genres || []).forEach(g => { %>
              <li><a class="dropdown-item" href="/Book?category=<%= encodeURIComponent(g) %>"><%= g %></a></li>
              <% }) %>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/wishlist"><i class="bi bi-heart me-1"></i>รายการโปรด</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/order-history"><i class="bi bi-clock-history me-1"></i>ประวัติการซื้อ</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/orders"><i class="bi bi-bag-check me-1"></i>จัดการคำสั่งซื้อ</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>


    <div class="container mt-4 mb-5">
        <h2 class="section-heading">จัดการหนังสือ</h2>

        <!-- Stats -->
        <div class="row g-3 mb-4">
          <div class="col-6 col-md-3">
            <div class="stat-card-admin">
              <div class="stat-icon-admin" style="background:#e8f4fd;color:#0d6efd;"><i class="bi bi-book"></i></div>
              <div class="stat-label-admin">หนังสือทั้งหมด</div>
              <div class="stat-val-admin"><%= stats.total %></div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-card-admin">
              <div class="stat-icon-admin" style="background:#fde8e8;color:#dc3545;"><i class="bi bi-x-circle"></i></div>
              <div class="stat-label-admin">สินค้าหมด</div>
              <div class="stat-val-admin"><%= stats.oos %></div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <a href="/admin/orders" style="text-decoration:none;">
            <div class="stat-card-admin">
              <div class="stat-icon-admin" style="background:#fff3cd;color:#856404;"><i class="bi bi-hourglass-split"></i></div>
              <div class="stat-label-admin">รอตรวจสอบ</div>
              <div class="stat-val-admin" style="<%= stats.pending > 0 ? 'color:#dc3545;' : '' %>"><%= stats.pending %></div>
            </div>
            </a>
          </div>
          <div class="col-6 col-md-3">
            <div class="stat-card-admin">
              <div class="stat-icon-admin" style="background:#d1fae5;color:#065f46;"><i class="bi bi-cash-stack"></i></div>
              <div class="stat-label-admin">ยอดขายรวม</div>
              <div class="stat-val-admin" style="font-size:16px;">฿<%= Number(stats.revenue).toLocaleString() %></div>
            </div>
          </div>
        </div>

        <!-- Charts -->
        <div class="row g-3 mb-4">
          <div class="col-md-7">
            <div class="card shadow-sm">
              <div class="card-header fw-bold"><i class="bi bi-bar-chart me-1"></i>ยอดขาย 30 วันล่าสุด</div>
              <div class="card-body"><canvas id="revenueChart" height="120"></canvas></div>
            </div>
          </div>
          <div class="col-md-5">
            <div class="card shadow-sm">
              <div class="card-header fw-bold"><i class="bi bi-trophy me-1"></i>หนังสือขายดี Top 5</div>
              <div class="card-body"><canvas id="topBooksChart" height="160"></canvas></div>
            </div>
          </div>
        </div>

        <div class="d-flex gap-2 mb-3 flex-wrap">
          <a href="/admin/add" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i>เพิ่มหนังสือ</a>
          <a href="/admin/orders" class="btn btn-outline-primary"><i class="bi bi-bag me-1"></i>Orders</a>
          <a href="/admin/users" class="btn btn-outline-secondary"><i class="bi bi-people me-1"></i>Users</a>
          <a href="/admin/coupons" class="btn btn-outline-warning"><i class="bi bi-ticket me-1"></i>Coupons</a>
        </div>
    
        <table class="table table-bordered mx-auto text-center">
            <thead class="table-dark">
                <tr>
                    <th>ชื่อหนังสือ</th>
                    <th>หมวดหมู่</th>
                    <th>สต๊อค</th>
                    <th>ราคา</th>
                    <th>จัดการ</th>
                </tr>
            </thead>
            <tbody>
                <% books.forEach(book => { %>
                <tr>
                    <td><%= book.title %></td>
                    <td><%= book.genre %></td>
                    <td><%= book.stock %></td>
                    <td>฿<%= book.price %></td>
                    <td>
                        <a href="/admin/edit/<%= book.id %>" class="btn btn-warning btn-sm">✏ แก้ไข</a>
                        <button class="btn btn-danger btn-sm"
                            data-id="<%= book.id %>"
                            data-title="<%= book.title %>"
                            onclick="openDeleteModal(this)">🗑 ลบ</button>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <!-- Delete confirm modal -->
    <div id="delete-confirm-modal" style="display:none;position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:12px;padding:28px 32px;max-width:400px;width:90%;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.25);">
            <div style="font-size:2.2rem;margin-bottom:8px;">🗑️</div>
            <h5 style="font-weight:700;margin-bottom:8px;">ยืนยันการลบ</h5>
            <p style="color:#555;font-size:14px;margin-bottom:4px;">คุณต้องการลบหนังสือ</p>
            <p id="delete-book-name" style="font-weight:700;color:#dc3545;font-size:15px;margin-bottom:20px;"></p>
            <p style="color:#888;font-size:13px;margin-bottom:20px;">การลบจะไม่สามารถกู้คืนได้</p>
            <div style="display:flex;gap:12px;justify-content:center;">
                <button onclick="closeDeleteModal()" style="padding:8px 24px;border-radius:8px;border:1px solid #ccc;background:#f8f9fa;font-size:14px;cursor:pointer;">ยกเลิก</button>
                <button onclick="confirmDelete()" style="padding:8px 24px;border-radius:8px;border:none;background:#dc3545;color:#fff;font-size:14px;font-weight:600;cursor:pointer;">ลบหนังสือ</button>
            </div>
        </div>
    </div>

    <!-- Modal แสดงผลการค้นหา -->
    <div class="modal fade" id="searchModal" tabindex="-1" aria-labelledby="searchModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="searchModalLabel">ผลการค้นหา</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row" id="search-results-container"></div>
                </div>
            </div>
        </div>
    </div>
    

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="/javascript/toast.js"></script>
<script src="/javascript/transition.js"></script>
<script src="/javascript/search.js"></script>
<script>
  Promise.all([
    fetch('/admin/stats/revenue').then(r => r.json()),
    fetch('/admin/stats/top-books').then(r => r.json())
  ]).then(([revenue, topBooks]) => {
    new Chart(document.getElementById('revenueChart'), {
      type: 'bar',
      data: {
        labels: revenue.map(r => r.day),
        datasets: [{ label: 'ยอดขาย (฿)', data: revenue.map(r => r.revenue),
          backgroundColor: 'rgba(220,53,69,.7)', borderRadius: 4 }]
      },
      options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });

    new Chart(document.getElementById('topBooksChart'), {
      type: 'doughnut',
      data: {
        labels: topBooks.map(b => b.title.length > 20 ? b.title.substring(0,20)+'…' : b.title),
        datasets: [{ data: topBooks.map(b => b.total_sold),
          backgroundColor: ['#dc3545','#fd7e14','#ffc107','#198754','#0d6efd'] }]
      },
      options: { plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } } }
    });
  });
</script>

<script>
    let deleteTargetId = null;

    function openDeleteModal(btn) {
        deleteTargetId = btn.dataset.id;
        document.getElementById('delete-book-name').textContent = '"' + btn.dataset.title + '"';
        const modal = document.getElementById('delete-confirm-modal');
        modal.style.display = 'flex';
    }

    function closeDeleteModal() {
        document.getElementById('delete-confirm-modal').style.display = 'none';
        deleteTargetId = null;
    }

    async function confirmDelete() {
        if (!deleteTargetId) return;
        closeDeleteModal();
        try {
            const res = await fetch(`/admin/delete/${deleteTargetId}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                showToast('ลบหนังสือสำเร็จ', 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(data.message || 'เกิดข้อผิดพลาด', 'error');
            }
        } catch {
            showToast('เกิดข้อผิดพลาดในการเชื่อมต่อ', 'error');
        }
    }

    document.getElementById('delete-confirm-modal').addEventListener('click', function(e) {
        if (e.target === this) closeDeleteModal();
    });
</script>
</body>
</html>
