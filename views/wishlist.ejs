<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>รายการโปรด | NUI MANGA STORE</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
  <script src="/javascript/darkmode.js"></script>
</head>
<body>

  <!-- HEADER -->
  <header class="header py-2">
    <div class="container">
      <div class="row align-items-center g-2">
        <div class="col-md-4">
          <h1>NUI MANGA STORE</h1>
        </div>
        <div class="col-md-4">
          <div class="search-bar">
            <input type="text" id="search-input" placeholder="ค้นหาหนังสือการ์ตูน..." class="form-control">
            <button class="btn btn-danger" onclick="searchBooks()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-4 text-end d-flex align-items-center justify-content-end gap-2">
          <button id="dark-mode-btn" class="btn btn-outline-light" onclick="toggleDarkMode()" title="Dark Mode" style="padding:6px 10px;"><i class="bi bi-moon-fill"></i></button>
          <a href="/cart" class="btn btn-outline-light"><i class="bi bi-cart3"></i> ตะกร้า</a>
          <% if (user) { %>
            <button class="btn btn-outline-light position-relative" id="notif-btn" style="padding:6px 10px;" title="การแจ้งเตือน">
              <i class="bi bi-bell-fill"></i>
              <% if (unreadNotifCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:10px;"><%= unreadNotifCount %></span>
              <% } %>
            </button>
            <a href="/profile" class="btn btn-outline-light" title="โปรไฟล์" style="padding:6px 10px;"><i class="bi bi-person-gear"></i></a>
            <a href="/logout" class="btn btn-outline-light"><i class="bi bi-box-arrow-right"></i> ออก</a>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light"><i class="bi bi-person"></i> เข้าสู่ระบบ</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/home"><i class="bi bi-book-half me-1"></i>NUI MANGA STORE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">หมวดหมู่</a>
            <ul class="dropdown-menu">
              <% (genres || []).forEach(g => { %>
              <li><a class="dropdown-item" href="/Book?category=<%= encodeURIComponent(g) %>"><%= g %></a></li>
              <% }) %>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/Book">หนังสือทั้งหมด</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/wishlist"><i class="bi bi-heart-fill me-1"></i>รายการโปรด</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/order-history"><i class="bi bi-clock-history me-1"></i>ประวัติการซื้อ</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <div class="container py-5">
      <h2 class="section-heading mb-4"><i class="bi bi-heart-fill me-2 text-danger"></i>รายการโปรดของฉัน</h2>

      <% if (books.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-heart" style="font-size:3rem;color:#dee2e6;"></i>
        <p class="mt-3 text-muted">ยังไม่มีหนังสือในรายการโปรด</p>
        <a href="/Book" class="btn btn-danger mt-2">เลือกดูหนังสือ</a>
      </div>
      <% } else { %>
      <div class="row row-cols-2 row-cols-md-4 g-3">
        <% books.forEach(book => { %>
        <div class="col" id="wish-card-<%= book.id %>">
          <div class="card h-100 shadow-sm">
            <a href="/book-details/<%= book.id %>">
              <img src="<%= book.image || '/uploads/default.png' %>"
                   onerror="this.src='/uploads/default.png'"
                   class="card-img-top" style="height:200px;object-fit:cover;" alt="<%= book.title %>">
            </a>
            <div class="card-body d-flex flex-column p-2">
              <a href="/book-details/<%= book.id %>" class="text-decoration-none text-dark">
                <h6 class="card-title mb-1" style="font-size:13px;"><%= book.title %></h6>
              </a>
              <span class="badge bg-secondary mb-1" style="font-size:11px;width:fit-content;"><%= book.genre %></span>
              <p class="text-danger fw-bold mb-2">฿<%= Number(book.price).toLocaleString() %></p>
              <div class="d-flex gap-1 mt-auto">
                <button class="btn btn-sm btn-danger flex-grow-1 btn-remove-wish" data-id="<%= book.id %>">
                  <i class="bi bi-heart-fill"></i> นำออก
                </button>
                <% if (book.stock > 0) { %>
                <button class="btn btn-sm btn-outline-dark flex-grow-1 btn-add-wish-cart"
                  data-id="<%= book.id %>" data-title="<%= book.title %>"
                  data-price="<%= book.price %>" data-image="<%= book.image %>">
                  <i class="bi bi-cart-plus"></i>
                </button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </main>

  <!-- SEARCH MODAL -->
  <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold">ผลการค้นหา</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3" id="search-results-container"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="bg-dark text-white text-center py-4">
    <p class="mb-1 fw-bold" style="color:#ffc107;">NUI MANGA STORE</p>
    <p class="mb-2" style="font-size:13px;">&copy; 2025 Nui&amp;Dream.com | All Rights Reserved</p>
    <p class="mb-0">
      <a href="#" class="text-white-50 me-3"><i class="bi bi-facebook"></i> Facebook</a>
      <a href="#" class="text-white-50 me-3"><i class="bi bi-twitter-x"></i> Twitter</a>
      <a href="#" class="text-white-50"><i class="bi bi-instagram"></i> Instagram</a>
    </p>
  </footer>

  <!-- Notification dropdown -->
  <div id="notif-dropdown" style="display:none;position:fixed;width:320px;max-height:400px;overflow-y:auto;background:#fff;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,.2);z-index:1020;">
    <div style="padding:12px 16px;border-bottom:1px solid #eee;font-weight:600;">การแจ้งเตือน</div>
    <div id="notif-list" style="padding:8px 0;"></div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascript/toast.js"></script>
  <script src="/javascript/transition.js"></script>
  <script src="/javascript/cart.js"></script>
  <script src="/javascript/search.js"></script>
  <script src="/javascript/notifications.js"></script>
  <script>
    document.querySelectorAll('.btn-remove-wish').forEach(btn => {
      btn.addEventListener('click', function() {
        const bookId = this.dataset.id;
        fetch('/wishlist/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ book_id: bookId })
        })
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            document.getElementById('wish-card-' + bookId).remove();
            showToast('ลบออกจากรายการโปรดแล้ว', 'warning');
            const grid = document.querySelector('.row.row-cols-2');
            if (grid && !grid.querySelector('.col')) {
              grid.closest('div.container').innerHTML =
                `<h2 class="section-heading mb-4"><i class="bi bi-heart-fill me-2 text-danger"></i>รายการโปรดของฉัน</h2>
                 <div class="text-center py-5">
                   <i class="bi bi-heart" style="font-size:3rem;color:#dee2e6;"></i>
                   <p class="mt-3 text-muted">ยังไม่มีหนังสือในรายการโปรด</p>
                   <a href="/Book" class="btn btn-danger mt-2">เลือกดูหนังสือ</a>
                 </div>`;
            }
          }
        });
      });
    });

    document.querySelectorAll('.btn-add-wish-cart').forEach(btn => {
      btn.addEventListener('click', function() {
        const { id, title, price, image } = this.dataset;
        addToCart(id, title, price, image);
      });
    });
  </script>
</body>
</html>
