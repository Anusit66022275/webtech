<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>จัดการคำสั่งซื้อ | NUI MANGA STORE</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/shared.css">
  <link rel="stylesheet" href="/css/order-history.css">
  <script src="/javascript/darkmode.js"></script>
  <style>
    /* ── Stats bar ── */
    .stats-bar {
      display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 28px;
    }
    .stat-card {
      flex: 1; min-width: 130px;
      background: var(--white); border-radius: var(--radius);
      box-shadow: var(--shadow); padding: 18px 20px;
      display: flex; align-items: center; gap: 14px;
    }
    .stat-icon {
      width: 44px; height: 44px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
    }
    .stat-icon.total   { background: #e8f4fd; color: #0d6efd; }
    .stat-icon.pending { background: #fff3cd; color: #856404; }
    .stat-icon.done    { background: #d1fae5; color: #065f46; }
    .stat-icon.cancel  { background: #fde8e8; color: #842029; }
    .stat-label { font-size: 12px; color: var(--muted); font-weight: 600; }
    .stat-value { font-size: 22px; font-weight: 800; line-height: 1.1; }

    /* ── Tab bar ── */
    .order-tabs {
      display: flex; gap: 0;
      background: var(--white); border-radius: var(--radius);
      box-shadow: var(--shadow); padding: 6px; margin-bottom: 24px;
    }
    .order-tab-btn {
      flex: 1; padding: 10px 16px; border: none;
      background: transparent; border-radius: 8px;
      font-size: 14px; font-weight: 700; cursor: pointer;
      color: var(--muted);
      display: flex; align-items: center; justify-content: center; gap: 8px;
      transition: all 0.18s; font-family: 'Sarabun', Arial, sans-serif;
    }
    .order-tab-btn.active { background: var(--dark-2); color: #fff; box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
    .order-tab-btn:not(.active):hover { background: #f1f5f9; color: var(--dark); }
    .tab-badge {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 22px; height: 22px; border-radius: 11px;
      font-size: 12px; font-weight: 800; padding: 0 6px;
    }
    .order-tab-btn.active .tab-badge    { background: rgba(255,255,255,0.2); color: #fff; }
    .order-tab-btn:not(.active) .tab-badge { background: #e2e4e8; color: var(--dark); }
    .tab-badge.has-pending { background: #ffc107 !important; color: #1a1d23 !important; }

    /* ── Tab panels ── */
    .tab-panel         { display: none; }
    .tab-panel.active  { display: block; }

    /* ── Order card overrides ── */
    .order-card-footer { gap: 12px; align-items: center; }
    .admin-actions { display: flex; gap: 8px; flex-wrap: wrap; }

    .btn-confirm {
      display: inline-flex; align-items: center; gap: 6px;
      background: #22c55e; color: #fff; border: none;
      border-radius: 8px; padding: 8px 18px;
      font-size: 14px; font-weight: 700; cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      font-family: 'Sarabun', Arial, sans-serif;
    }
    .btn-confirm:hover { background: #16a34a; transform: translateY(-1px); }

    .btn-cancel-order {
      display: inline-flex; align-items: center; gap: 6px;
      background: #fff; color: var(--red);
      border: 1.5px solid var(--red); border-radius: 8px;
      padding: 8px 18px; font-size: 14px; font-weight: 700;
      cursor: pointer; transition: all 0.2s;
      font-family: 'Sarabun', Arial, sans-serif;
    }
    .btn-cancel-order:hover { background: var(--red); color: #fff; transform: translateY(-1px); }

    .done-label { font-size: 13px; color: var(--muted); font-style: italic; }
    .status-cancelled { background: #fde8e8; color: #842029; }

    /* ── Slip button ── */
    .slip-thumb-btn {
      display: inline-flex; align-items: center; gap: 6px;
      background: #f8f9fa; color: var(--dark);
      border: 1.5px solid var(--border); border-radius: 8px;
      padding: 7px 14px; font-size: 13px; font-weight: 600;
      cursor: pointer; transition: all 0.15s;
      font-family: 'Sarabun', Arial, sans-serif;
    }
    .slip-thumb-btn:hover { background: var(--dark); color: #fff; border-color: var(--dark); }
    .slip-thumb-btn img { width: 28px; height: 28px; object-fit: cover; border-radius: 4px; }

    /* ── Confirm popup ── */
    .confirm-modal-overlay {
      position: fixed; top: 0; left: 0;
      width: 100vw; height: 100vh;
      background: rgba(0,0,0,0.55); backdrop-filter: blur(3px);
      z-index: 99990;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.2s ease;
    }
    .confirm-modal-overlay.open { opacity: 1; pointer-events: auto; }
    .confirm-modal-box {
      background: #fff; border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
      padding: 36px 32px 28px; max-width: 400px; width: calc(100% - 32px);
      text-align: center;
      transform: scale(0.92) translateY(12px);
      transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1);
    }
    .confirm-modal-overlay.open .confirm-modal-box { transform: scale(1) translateY(0); }
    .confirm-modal-icon {
      width: 64px; height: 64px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; margin: 0 auto 16px;
    }
    .confirm-modal-icon.success { background: #dcfce7; color: #16a34a; }
    .confirm-modal-icon.danger  { background: #fee2e2; color: #dc2626; }
    .confirm-modal-title { font-size: 18px; font-weight: 800; margin-bottom: 8px; }
    .confirm-modal-desc  { font-size: 14px; color: var(--muted); margin-bottom: 24px; line-height: 1.6; }
    .confirm-modal-actions { display: flex; gap: 10px; justify-content: center; }
    .confirm-modal-actions button {
      flex: 1; max-width: 140px; padding: 10px 0;
      border-radius: 10px; font-size: 15px; font-weight: 700;
      border: none; cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
      font-family: 'Sarabun', Arial, sans-serif;
    }
    .confirm-modal-actions button:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-modal-back        { background: #f1f5f9; color: #475569; }
    .btn-modal-confirm-yes { background: #22c55e; color: #fff; }
    .btn-modal-cancel-yes  { background: var(--red); color: #fff; }

    /* ── Slip viewer ── */
    .slip-viewer-overlay {
      position: fixed; top: 0; left: 0;
      width: 100vw; height: 100vh;
      background: rgba(0,0,0,0.80); z-index: 99995;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.2s ease;
    }
    .slip-viewer-overlay.open { opacity: 1; pointer-events: auto; }
    .slip-viewer-overlay img {
      max-width: 90vw; max-height: 85vh;
      border-radius: 12px; box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    }
    .slip-close-btn {
      position: absolute; top: 18px; right: 22px;
      background: rgba(255,255,255,0.15); border: none;
      color: #fff; font-size: 22px; width: 40px; height: 40px;
      border-radius: 50%; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .slip-close-btn:hover { background: rgba(255,255,255,0.3); }

    @media (max-width: 576px) {
      .stats-bar { gap: 10px; }
      .stat-card { padding: 14px 16px; }
      .confirm-modal-box { padding: 28px 20px 22px; }
      .order-tab-btn { font-size: 13px; padding: 9px 10px; }
    }

    /* ════ DARK MODE ════ */
    [data-theme="dark"] .stat-icon.total   { background: #1a2d4a; color: #60a5fa; }
    [data-theme="dark"] .stat-icon.pending { background: #3a2e00; color: #fbbf24; }
    [data-theme="dark"] .stat-icon.done    { background: #063a24; color: #4ade80; }
    [data-theme="dark"] .stat-icon.cancel  { background: #3a0d0d; color: #f87171; }
    [data-theme="dark"] .order-tab-btn:not(.active):hover { background: #252836; color: #dde1ec; }
    [data-theme="dark"] .order-tab-btn:not(.active) .tab-badge { background: #2d3348; color: #dde1ec; }
    [data-theme="dark"] .confirm-modal-box { background: #1c1f2e; color: #dde1ec; }
    [data-theme="dark"] .confirm-modal-title { color: #dde1ec; }
    [data-theme="dark"] .btn-modal-back { background: #252836; color: #8b95a8; }
    [data-theme="dark"] .slip-thumb-btn { background: #252836; border-color: #2d3348; color: #dde1ec; }
    [data-theme="dark"] .slip-thumb-btn:hover { background: #dde1ec; color: #1c1f2e; border-color: #dde1ec; }
    [data-theme="dark"] .btn-cancel-order { background: #1c1f2e; }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="header py-2">
    <div class="container">
      <div class="row align-items-center g-2">
        <div class="col-md-4"><h1>NUI MANGA STORE</h1></div>
        <div class="col-md-4">
          <div class="search-bar">
            <input type="text" id="search-input" placeholder="ค้นหาหนังสือการ์ตูน..." class="form-control">
            <button class="btn btn-danger" onclick="searchBooks()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-4 text-end d-flex align-items-center justify-content-end gap-2">
          <button id="dark-mode-btn" class="btn btn-outline-light" onclick="toggleDarkMode()" title="Dark Mode" style="padding:6px 10px;"><i class="bi bi-moon-fill"></i></button>
          <a href="/cart" class="btn btn-outline-light"><i class="bi bi-cart3"></i> ตะกร้า</a>
          <% if (user) { %>
            <a href="/logout" class="btn btn-outline-light"><i class="bi bi-box-arrow-right"></i> ออก</a>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="/home"><i class="bi bi-book-half me-1"></i>NUI MANGA STORE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/admin"><i class="bi bi-book me-1"></i>จัดการหนังสือ</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/admin/orders"><i class="bi bi-bag-check me-1"></i>จัดการคำสั่งซื้อ</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main>
    <div class="container py-5">
      <h2 class="section-heading mb-4"><i class="bi bi-bag-check me-2"></i>จัดการคำสั่งซื้อ</h2>

      <%
        const pendingOrders  = orders.filter(o => o.payment_status === 'Pending');
        const doneOrders     = orders.filter(o => o.payment_status !== 'Pending');
        const completedCount = orders.filter(o => o.payment_status === 'Completed').length;
        const cancelledCount = orders.filter(o => o.payment_status === 'Cancelled').length;
      %>

      <!-- Stats bar -->
      <div class="stats-bar">
        <div class="stat-card">
          <div class="stat-icon total"><i class="bi bi-receipt"></i></div>
          <div><div class="stat-label">ทั้งหมด</div><div class="stat-value"><%= orders.length %></div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon pending"><i class="bi bi-hourglass-split"></i></div>
          <div><div class="stat-label">รอตรวจสอบ</div><div class="stat-value"><%= pendingOrders.length %></div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon done"><i class="bi bi-check-circle"></i></div>
          <div><div class="stat-label">ชำระแล้ว</div><div class="stat-value"><%= completedCount %></div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon cancel"><i class="bi bi-x-circle"></i></div>
          <div><div class="stat-label">ยกเลิกแล้ว</div><div class="stat-value"><%= cancelledCount %></div></div>
        </div>
      </div>

      <!-- Tab bar -->
      <div class="order-tabs">
        <button class="order-tab-btn active" id="btn-tab-pending" onclick="switchTab('pending')">
          <i class="bi bi-hourglass-split"></i> รอดำเนินการ
          <span class="tab-badge <%= pendingOrders.length > 0 ? 'has-pending' : '' %>"><%= pendingOrders.length %></span>
        </button>
        <button class="order-tab-btn" id="btn-tab-done" onclick="switchTab('done')">
          <i class="bi bi-archive"></i> ดำเนินการแล้ว
          <span class="tab-badge"><%= doneOrders.length %></span>
        </button>
      </div>

      <!-- ── Tab: รอดำเนินการ ── -->
      <div class="tab-panel active" id="panel-pending">
        <% if (pendingOrders.length === 0) { %>
          <div class="empty-history">
            <i class="bi bi-check2-circle"></i>
            <p>ไม่มีคำสั่งซื้อที่รอดำเนินการ</p>
            <a href="/admin">กลับหน้าจัดการหนังสือ</a>
          </div>
        <% } else { %>
          <% pendingOrders.forEach(order => { %>
          <div class="order-card">
            <div class="order-card-header">
              <div>
                <div class="order-id"><i class="bi bi-hash"></i>Order <%= order.order_id %></div>
                <div class="order-date"><i class="bi bi-calendar3 me-1"></i><%= new Date(order.order_date).toLocaleDateString('th-TH', {year:'numeric',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
              </div>
              <span class="status-badge status-pending">
                <i class="bi bi-hourglass-split me-1"></i>รอตรวจสอบ
              </span>
            </div>
            <div class="order-card-body">
              <div class="order-meta">
                <div class="order-meta-item">
                  <div class="meta-label">ชื่อผู้รับ</div>
                  <div class="meta-value"><%= order.user_name %></div>
                </div>
                <div class="order-meta-item">
                  <div class="meta-label">เบอร์โทร</div>
                  <div class="meta-value"><%= order.phone_number %></div>
                </div>
                <div class="order-meta-item" style="grid-column: 1 / -1;">
                  <div class="meta-label">ที่อยู่จัดส่ง</div>
                  <div class="meta-value"><%= order.address %></div>
                </div>
              </div>
              <ul class="order-items-list">
                <% order.items.forEach(item => { %>
                <li class="order-item">
                  <span class="item-name"><i class="bi bi-book me-2 text-muted"></i><%= item.title %></span>
                  <span class="item-qty">× <%= item.quantity %></span>
                  <span class="item-price">฿<%= Number(item.price * item.quantity).toLocaleString() %></span>
                </li>
                <% }) %>
              </ul>
            </div>
            <div class="order-card-footer">
              <div>
                <div class="order-total-label">ยอดรวมทั้งหมด</div>
                <div class="order-total-amount">฿<%= Number(order.total_price).toLocaleString() %></div>
              </div>
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <% if (order.payment_slip) { %>
                <button class="slip-thumb-btn" onclick="viewSlip('<%= order.payment_slip %>')">
                  <img src="<%= order.payment_slip %>" alt="สลิป" onerror="this.style.display='none'">
                  <i class="bi bi-image"></i> ดูสลิป
                </button>
                <% } %>
                <div class="admin-actions">
                  <button class="btn-confirm" onclick="openConfirm(<%= order.order_id %>, 'Completed')">
                    <i class="bi bi-check-lg"></i> ยืนยันการชำระ
                  </button>
                  <button class="btn-cancel-order" onclick="openConfirm(<%= order.order_id %>, 'Cancelled')">
                    <i class="bi bi-x-lg"></i> ยกเลิก
                  </button>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        <% } %>
      </div>

      <!-- ── Tab: ดำเนินการแล้ว ── -->
      <div class="tab-panel" id="panel-done">
        <% if (doneOrders.length === 0) { %>
          <div class="empty-history">
            <i class="bi bi-inbox"></i>
            <p>ยังไม่มีคำสั่งซื้อที่ดำเนินการแล้ว</p>
            <a href="/admin">กลับหน้าจัดการหนังสือ</a>
          </div>
        <% } else { %>
          <% doneOrders.forEach(order => { %>
          <div class="order-card">
            <div class="order-card-header">
              <div>
                <div class="order-id"><i class="bi bi-hash"></i>Order <%= order.order_id %></div>
                <div class="order-date"><i class="bi bi-calendar3 me-1"></i><%= new Date(order.order_date).toLocaleDateString('th-TH', {year:'numeric',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
              </div>
              <span class="status-badge status-<%= order.payment_status.toLowerCase() %>">
                <% if (order.payment_status === 'Completed') { %>
                  <i class="bi bi-check-circle me-1"></i>ชำระแล้ว
                <% } else if (order.payment_status === 'Shipped') { %>
                  <i class="bi bi-truck me-1"></i>จัดส่งแล้ว
                <% } else if (order.payment_status === 'Delivered') { %>
                  <i class="bi bi-house-check me-1"></i>ส่งถึงแล้ว
                <% } else { %>
                  <i class="bi bi-x-circle me-1"></i>ยกเลิก
                <% } %>
              </span>
            </div>
            <div class="order-card-body">
              <div class="order-meta">
                <div class="order-meta-item">
                  <div class="meta-label">ชื่อผู้รับ</div>
                  <div class="meta-value"><%= order.user_name %></div>
                </div>
                <div class="order-meta-item">
                  <div class="meta-label">เบอร์โทร</div>
                  <div class="meta-value"><%= order.phone_number %></div>
                </div>
                <div class="order-meta-item" style="grid-column: 1 / -1;">
                  <div class="meta-label">ที่อยู่จัดส่ง</div>
                  <div class="meta-value"><%= order.address %></div>
                </div>
              </div>
              <ul class="order-items-list">
                <% order.items.forEach(item => { %>
                <li class="order-item">
                  <span class="item-name"><i class="bi bi-book me-2 text-muted"></i><%= item.title %></span>
                  <span class="item-qty">× <%= item.quantity %></span>
                  <span class="item-price">฿<%= Number(item.price * item.quantity).toLocaleString() %></span>
                </li>
                <% }) %>
              </ul>
            </div>
            <div class="order-card-footer">
              <div>
                <div class="order-total-label">ยอดรวมทั้งหมด</div>
                <div class="order-total-amount">฿<%= Number(order.total_price).toLocaleString() %></div>
              </div>
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <% if (order.payment_slip) { %>
                <button class="slip-thumb-btn" onclick="viewSlip('<%= order.payment_slip %>')">
                  <img src="<%= order.payment_slip %>" alt="สลิป" onerror="this.style.display='none'">
                  <i class="bi bi-image"></i> ดูสลิป
                </button>
                <% } %>
                <% if (order.payment_status === 'Completed') { %>
                <button class="btn btn-outline-primary btn-sm" onclick="openConfirm(<%= order.order_id %>, 'Shipped')" style="font-family:'Sarabun',Arial,sans-serif;">
                  <i class="bi bi-truck me-1"></i> จัดส่งสินค้า
                </button>
                <% } else { %>
                <span class="done-label"><i class="bi bi-check2-all me-1"></i>ดำเนินการแล้ว</span>
                <% } %>
              </div>
            </div>
          </div>
          <% }) %>
        <% } %>
      </div>

    </div>
  </main>

  <!-- FOOTER -->
  <footer class="bg-dark text-white text-center py-4">
    <p class="mb-1 fw-bold" style="color:#ffc107;">NUI MANGA STORE</p>
    <p class="mb-2" style="font-size:13px;">&copy; 2025 Nui&amp;Dream.com | All Rights Reserved</p>
    <p class="mb-0">
      <a href="#" class="text-white-50 me-3"><i class="bi bi-facebook"></i></a>
      <a href="#" class="text-white-50 me-3"><i class="bi bi-twitter-x"></i></a>
      <a href="#" class="text-white-50"><i class="bi bi-instagram"></i></a>
    </p>
  </footer>

  <!-- Confirm Popup -->
  <div class="confirm-modal-overlay" id="confirmOverlay">
    <div class="confirm-modal-box">
      <div class="confirm-modal-icon" id="confirmIcon"><i id="confirmIconInner"></i></div>
      <div class="confirm-modal-title" id="confirmTitle"></div>
      <div class="confirm-modal-desc"  id="confirmDesc"></div>
      <div class="confirm-modal-actions">
        <button class="btn-modal-back" onclick="closeConfirm()">
          <i class="bi bi-arrow-left me-1"></i>ย้อนกลับ
        </button>
        <button id="confirmYesBtn" onclick="doUpdateStatus()"></button>
      </div>
    </div>
  </div>

  <!-- Slip Viewer -->
  <div class="slip-viewer-overlay" id="slipViewer" onclick="closeSlip()">
    <button class="slip-close-btn" onclick="closeSlip()"><i class="bi bi-x-lg"></i></button>
    <img id="slipImg" src="" alt="สลิปการโอน">
  </div>

  <!-- Search Modal -->
  <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title fw-bold">ผลการค้นหา</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3" id="search-results-container"></div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascript/toast.js"></script>
  <script src="/javascript/search.js"></script>
  <script>
    // ── Tab switching ──
    function switchTab(tab) {
      document.querySelectorAll('.order-tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.getElementById('btn-tab-' + tab).classList.add('active');
      document.getElementById('panel-'  + tab).classList.add('active');
    }

    // กลับมาที่ tab ที่บันทึกไว้หลัง reload
    const savedTab = sessionStorage.getItem('adminOrderTab');
    if (savedTab) { switchTab(savedTab); sessionStorage.removeItem('adminOrderTab'); }

    // ── Confirm popup ──
    let pendingOrderId = null, pendingNewStatus = null;

    function openConfirm(orderId, status) {
      pendingOrderId   = orderId;
      pendingNewStatus = status;

      const icon   = document.getElementById('confirmIcon');
      const inner  = document.getElementById('confirmIconInner');
      const title  = document.getElementById('confirmTitle');
      const desc   = document.getElementById('confirmDesc');
      const yesBtn = document.getElementById('confirmYesBtn');

      if (status === 'Completed') {
        icon.className  = 'confirm-modal-icon success';
        inner.className = 'bi bi-check-circle-fill';
        title.textContent = 'ยืนยันการชำระเงิน?';
        desc.textContent  = `Order #${orderId} จะถูกย้ายไปแท็บ "ดำเนินการแล้ว"`;
        yesBtn.className  = 'btn-modal-confirm-yes';
        yesBtn.innerHTML  = '<i class="bi bi-check-lg me-1"></i>ยืนยัน';
      } else if (status === 'Shipped') {
        icon.className  = 'confirm-modal-icon success';
        inner.className = 'bi bi-truck';
        title.textContent = 'ยืนยันการจัดส่ง?';
        desc.textContent  = `Order #${orderId} จะถูกอัปเดตเป็น "จัดส่งแล้ว"`;
        yesBtn.className  = 'btn-modal-confirm-yes';
        yesBtn.innerHTML  = '<i class="bi bi-truck me-1"></i>ยืนยันจัดส่ง';
      } else {
        icon.className  = 'confirm-modal-icon danger';
        inner.className = 'bi bi-x-circle-fill';
        title.textContent = 'ยกเลิกคำสั่งซื้อ?';
        desc.textContent  = `Order #${orderId} จะถูกยกเลิก และย้ายไปแท็บ "ดำเนินการแล้ว"`;
        yesBtn.className  = 'btn-modal-cancel-yes';
        yesBtn.innerHTML  = '<i class="bi bi-x-lg me-1"></i>ยกเลิกออเดอร์';
      }
      document.getElementById('confirmOverlay').classList.add('open');
    }

    function closeConfirm() {
      document.getElementById('confirmOverlay').classList.remove('open');
      pendingOrderId = null; pendingNewStatus = null;
    }

    async function doUpdateStatus() {
      if (!pendingOrderId || !pendingNewStatus) return;
      const orderId = pendingOrderId;
      const status  = pendingNewStatus;
      closeConfirm();

      const res  = await fetch(`/admin/orders/${orderId}/status`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
      });
      const data = await res.json();

      if (data.success) {
        const msg  = status === 'Completed' ? 'ยืนยันการชำระเงินสำเร็จ'
                   : status === 'Shipped'   ? 'อัปเดตสถานะจัดส่งแล้ว'
                   : 'ยกเลิกคำสั่งซื้อสำเร็จ';
        const type = status === 'Cancelled' ? 'warning' : 'success';
        showToast(msg, type);
        sessionStorage.setItem('adminOrderTab', 'pending');
        setTimeout(() => location.reload(), 1200);
      } else {
        showToast('เกิดข้อผิดพลาด กรุณาลองใหม่', 'error');
      }
    }

    document.getElementById('confirmOverlay').addEventListener('click', function(e) {
      if (e.target === this) closeConfirm();
    });

    // ── Slip viewer ──
    function viewSlip(src) {
      document.getElementById('slipImg').src = src;
      document.getElementById('slipViewer').classList.add('open');
    }
    function closeSlip() {
      document.getElementById('slipViewer').classList.remove('open');
    }
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') { closeConfirm(); closeSlip(); }
    });
  </script>
</body>
</html>
